# 房产监控配置
# 复制为 .env 文件并填入你的真实配置

# 企业微信机器人Webhook（推荐，免费）
# 获取方式：企业微信APP → 进入群聊 → 右上角... → 添加群机器人 → 复制Webhook地址
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# Server酱SendKey（备用推送方式）
# 获取方式：https://sct.ftqq.com/ 用GitHub账号登录
SERVERCHAN_KEY=YOUR_KEY_HERE

# 钉钉机器人Webhook（备用）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN_HERE
